# ─────────────────────────────────────────────────────────────────────────
# Bumplog harness environment — TEMPLATE ONLY (no real values here).
# Copy to `.env` (gitignored) and fill in. NEVER commit `.env`.
# Values are loaded as shell exports: `set -a; source .env; set +a`
# ─────────────────────────────────────────────────────────────────────────

# PostHog — public project/ingest key. Client-visible by design (ships in the
# site snippet). Starts with `phc_`.
export POSTHOG_PROJECT_API_KEY=phc_REPLACE_ME

# PostHog — read-scoped PERSONAL API key. THE real secret. Used only by the
# harness read client (HogQL query API). Never exposed to the browser.
export POSTHOG_PERSONAL_API_KEY=phx_REPLACE_ME

# PostHog — numeric project id (for the query API path /api/projects/<id>/query).
export POSTHOG_PROJECT_ID=REPLACE_ME

# PostHog — region host. e.g. https://us.i.posthog.com or https://eu.i.posthog.com
export POSTHOG_HOST=https://us.i.posthog.com

# GitHub — READ-ONLY fine-grained PAT (public repo read / contents:read).
# NOT the gh CLI token. Used by the release pipeline (5,000 req/hr authed).
export GITHUB_TOKEN=github_pat_REPLACE_ME

# ── Astro build-time public vars (mirrors of the two PostHog public values) ──
# Astro only exposes vars prefixed PUBLIC_ to client code. These feed the
# in-page snippet. Keep them equal to the POSTHOG_* values above.
export PUBLIC_POSTHOG_KEY=phc_REPLACE_ME
export PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
