---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container container--wide site-footer__inner">
    <p class="muted">
      Bumplog, the self-hosted update tracker. Source of truth: the GitHub API.
    </p>
    <p class="muted">
      <a href="/feed.xml">RSS</a>
      <span aria-hidden="true">·</span>
      <a href="/api/v1/apps.json">API</a>
      <span aria-hidden="true">·</span>
      <a href="/feedback/">Send feedback</a>
      <span aria-hidden="true">·</span>
      <span>&copy; {year} Bumplog</span>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
    padding-block: 1.5rem;
  }
  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 1.5rem;
    font-size: 0.9rem;
  }
  .site-footer__inner p {
    margin: 0;
  }
  .site-footer__inner span {
    margin-inline: 0.4rem;
  }
</style>
