---
import type { SafeToUpdate } from '../data/types';

interface Props {
  status: SafeToUpdate;
  /** "md" (default) for inline use; "sm" for dense card rows. */
  size?: 'sm' | 'md';
}

const { status, size = 'md' } = Astro.props;

// Accessible: each state carries its own TEXT label, not color alone.
const LABELS: Record<SafeToUpdate, string> = {
  safe: 'Safe to update',
  caution: 'Update with care',
  breaking: 'Breaking changes',
  unknown: 'Not yet assessed',
};

const label = LABELS[status];
---

<span class:list={['badge', `badge--${status}`, { 'badge--sm': size === 'sm' }]} role="status">
  <span class="badge__glyph" aria-hidden="true">
    {status === 'safe' && (
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3.5 8.5l3 3 6-7" /></svg>
    )}
    {status === 'caution' && (
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2.5L14.5 13.5H1.5L8 2.5z" /><path d="M8 6.6v3" /><path d="M8 11.7h.01" /></svg>
    )}
    {status === 'breaking' && (
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l8 8M12 4l-8 8" /></svg>
    )}
    {status === 'unknown' && (
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 13.5a5.5 5.5 0 100-11 5.5 5.5 0 000 11z" opacity="0.55" /><path d="M8 7.5v3.2" /><path d="M8 5.1h.01" /></svg>
    )}
  </span>
  {label}
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.6rem 0.25rem 0.45rem;
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    font-weight: 540;
    line-height: 1.2;
    border: 1px solid transparent;
    white-space: nowrap;
  }
  .badge--sm {
    font-size: var(--text-xs);
    padding: 0.18rem 0.5rem 0.18rem 0.36rem;
    gap: 0.28rem;
  }
  .badge__glyph {
    display: inline-flex;
    flex: none;
  }
  .badge__glyph svg {
    width: 0.95rem;
    height: 0.95rem;
    display: block;
  }
  .badge--sm .badge__glyph svg {
    width: 0.8rem;
    height: 0.8rem;
  }
  .badge--safe {
    background: var(--status-safe-bg);
    color: var(--status-safe-fg);
    border-color: var(--status-safe-border);
  }
  .badge--caution {
    background: var(--status-caution-bg);
    color: var(--status-caution-fg);
    border-color: var(--status-caution-border);
  }
  .badge--breaking {
    background: var(--status-breaking-bg);
    color: var(--status-breaking-fg);
    border-color: var(--status-breaking-border);
  }
  .badge--unknown {
    background: var(--status-unknown-bg);
    color: var(--status-unknown-fg);
    border-color: var(--status-unknown-border);
  }
</style>
