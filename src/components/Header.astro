---
// Site header: brand wordmark + logo mark + primary nav with active state.
const links = [
  { href: '/', label: 'Trackers' },
  { href: '/stacks/', label: 'Stacks' },
  { href: '/journal/', label: 'Journal' },
  { href: '/feedback/', label: 'Feedback' },
];

// Normalize the current path for active-link matching (trailingSlash: ignore).
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
function isActive(href: string) {
  const target = href.replace(/\/+$/, '') || '/';
  if (target === '/') return path === '/';
  return path === target || path.startsWith(`${target}/`);
}
---

<header class="site-header">
  <div class="container container--wide site-header__inner">
    <a class="wordmark" href="/">
      <span class="wordmark__mark" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="26" height="26">
          <rect width="32" height="32" rx="8" fill="var(--color-accent)" />
          <path d="M16 8 L23 17 H18.7 V24 H13.3 V17 H9 Z" fill="var(--color-accent-fg)" />
        </svg>
      </span>
      <span class="wordmark__text">Bumplog</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { 'nav-link--active': isActive(link.href) }]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
    position: sticky;
    top: 0;
    z-index: 20;
  }
  .site-header__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 1.5rem;
    padding-block: 0.85rem;
  }
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 770;
    font-size: 1.25rem;
    letter-spacing: -0.025em;
    color: var(--color-text);
    text-decoration: none;
  }
  .wordmark__mark {
    display: inline-flex;
  }
  .wordmark__mark svg {
    display: block;
    border-radius: 8px;
  }
  nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .nav-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.35rem 0.6rem;
    border-radius: var(--radius-sm);
    transition: color var(--dur) var(--ease), background var(--dur) var(--ease);
  }
  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-bg-sunken);
  }
  .nav-link--active {
    color: var(--color-text);
    background: var(--color-bg-sunken);
  }
</style>
