---
import BaseLayout from '../layouts/BaseLayout.astro';
import SafeToUpdateBadge from '../components/SafeToUpdateBadge.astro';
import apps from '../data/apps.json';
import { toBadgeStatus, type App, type SafeToUpdate } from '../data/types';

const trackedApps = apps as App[];

// Assessed apps lead, ordered by severity (safe, caution, breaking), pending
// last. Stable name order within a group.
const ORDER: Record<SafeToUpdate, number> = { safe: 0, caution: 1, breaking: 2, unknown: 3 };
const sorted = [...trackedApps].sort((a, b) => {
  const sa = ORDER[toBadgeStatus(a.safeToUpdate)];
  const sb = ORDER[toBadgeStatus(b.safeToUpdate)];
  if (sa !== sb) return sa - sb;
  return a.name.localeCompare(b.name);
});

const total = trackedApps.length;
const assessed = trackedApps.filter((a) => a.safeToUpdate != null).length;
const counts = {
  safe: trackedApps.filter((a) => a.safeToUpdate === 'safe').length,
  caution: trackedApps.filter((a) => a.safeToUpdate === 'caution').length,
  breaking: trackedApps.filter((a) => a.safeToUpdate === 'breaking').length,
  unknown: trackedApps.filter((a) => a.safeToUpdate == null).length,
};

const FILTERS: { key: SafeToUpdate | 'all'; label: string }[] = [
  { key: 'all', label: 'All' },
  { key: 'safe', label: 'Safe' },
  { key: 'caution', label: 'Caution' },
  { key: 'breaking', label: 'Breaking' },
  { key: 'unknown', label: 'Pending' },
];
const activeFilters = FILTERS.filter((f) => f.key === 'all' || counts[f.key as SafeToUpdate] > 0);
---

<BaseLayout
  title="Bumplog — the self-hosted update tracker"
  description="Bumplog tracks releases of popular self-hosted apps and tells you whether it is safe to update: summarized changelogs and breaking-change warnings, every datum traceable to its GitHub release."
>
  <div class="page-hero">
    <h1>Is it <span class="accent">safe</span> to update?</h1>
    <p class="lede">
      Bumplog watches releases of popular self-hosted apps and tells you, in plain
      language, whether it's safe to update, with the breaking changes called out and
      every verdict traceable to its GitHub release.
    </p>

    {total > 0 && (
      <ul class="summary" aria-label="Tracking summary">
        <li class="summary__item"><span class="summary__num">{total}</span> tracked</li>
        <li class="summary__item"><span class="summary__num">{assessed}</span> assessed</li>
        {counts.safe > 0 && (
          <li class="summary__item"><span class="summary__dot summary__dot--safe"></span><span class="summary__num">{counts.safe}</span> safe</li>
        )}
        {counts.caution > 0 && (
          <li class="summary__item"><span class="summary__dot summary__dot--caution"></span><span class="summary__num">{counts.caution}</span> caution</li>
        )}
        {counts.breaking > 0 && (
          <li class="summary__item"><span class="summary__dot summary__dot--breaking"></span><span class="summary__num">{counts.breaking}</span> breaking</li>
        )}
        {counts.unknown > 0 && (
          <li class="summary__item"><span class="summary__dot summary__dot--unknown"></span><span class="summary__num">{counts.unknown}</span> pending</li>
        )}
      </ul>
    )}
  </div>

  <div class="apps-head">
    <h2 id="tracked-heading">Tracked apps</h2>
    {activeFilters.length > 2 && (
      <div class="filters" role="group" aria-label="Filter apps by update safety" hidden>
        {activeFilters.map((f) => (
          <button type="button" class="filter-chip" data-filter={f.key} aria-pressed={f.key === 'all' ? 'true' : 'false'}>{f.label}</button>
        ))}
      </div>
    )}
  </div>

  {total === 0 ? (
    <div class="empty-state"><p>No apps are being tracked yet. Check back soon.</p></div>
  ) : (
    <ul class="app-list" id="app-grid" aria-labelledby="tracked-heading">
      {sorted.map((app) => {
        const status = toBadgeStatus(app.safeToUpdate);
        return (
          <li class="app-list__item" data-status={status}>
            <a class="app-row" href={`/apps/${app.slug}/`}>
              <span class="app-row__main">
                <span class="app-row__name">{app.name}</span>
                <span class="app-row__repo mono">{app.repo}</span>
              </span>
              <span class="app-row__meta">
                {app.latestVersion ? (
                  <span class="app-row__version mono">{app.latestVersion}</span>
                ) : (
                  <span class="app-row__version mono placeholder">pending</span>
                )}
                <SafeToUpdateBadge status={status} size="sm" />
              </span>
            </a>
          </li>
        );
      })}
    </ul>
  )}

  <p class="empty-state filter-empty" id="filter-empty" hidden>No apps match this filter.</p>
</BaseLayout>

<script>
  // Progressive enhancement: client-side status filtering. The list renders and
  // is crawlable without JS; chips reveal only when JS runs.
  const filters = document.querySelector<HTMLElement>('.filters');
  const grid = document.getElementById('app-grid');
  const emptyMsg = document.getElementById('filter-empty');
  if (filters && grid) {
    filters.hidden = false;
    const chips = Array.from(filters.querySelectorAll<HTMLButtonElement>('.filter-chip'));
    const items = Array.from(grid.querySelectorAll<HTMLElement>('.app-list__item'));
    function apply(filter: string) {
      let visible = 0;
      for (const item of items) {
        const match = filter === 'all' || item.dataset.status === filter;
        item.hidden = !match;
        if (match) visible += 1;
      }
      if (emptyMsg) emptyMsg.hidden = visible !== 0;
    }
    for (const chip of chips) {
      chip.addEventListener('click', () => {
        for (const c of chips) c.setAttribute('aria-pressed', String(c === chip));
        apply(chip.dataset.filter ?? 'all');
      });
    }
  }
</script>

<style>
  .apps-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem 1rem;
  }
  .apps-head h2 {
    margin-block: 0 0;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .filter-chip {
    background: transparent;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.28rem 0.7rem;
    font-size: var(--text-sm);
    font-weight: 500;
  }
  .filter-chip:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text);
  }
  .filter-chip[aria-pressed='true'] {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  .app-list {
    list-style: none;
    margin: 1.1rem 0 0;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    overflow: hidden;
  }
  .app-list__item + .app-list__item {
    border-top: 1px solid var(--color-border);
  }
  .app-list__item[hidden] {
    display: none;
  }

  .app-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem 1.25rem;
    padding: 0.95rem 1.15rem;
    text-decoration: none;
    color: inherit;
    transition: background var(--dur) var(--ease);
  }
  .app-row:hover {
    background: var(--color-surface-2);
  }
  .app-row__main {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .app-row__name {
    font-weight: 540;
    letter-spacing: -0.01em;
  }
  .app-row__repo {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
  .app-row__meta {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .app-row__version {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    white-space: nowrap;
  }
</style>
