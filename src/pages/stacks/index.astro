---
import BaseLayout from '../../layouts/BaseLayout.astro';
import apps from '../../data/apps.json';
import stacks from '../../data/stacks.json';
import { type App, type Stack } from '../../data/types';

const allStacks = stacks as Stack[];
const appBySlug = new Map((apps as App[]).map((app) => [app.slug, app]));

// Per-stack: how many apps are assessed vs pending, for an at-a-glance preview.
function stackStatus(stack: Stack) {
  const resolved = stack.appSlugs
    .map((slug) => appBySlug.get(slug))
    .filter((a): a is App => a !== undefined);
  const assessed = resolved.filter((a) => a.safeToUpdate != null).length;
  return { total: resolved.length, assessed };
}
---

<BaseLayout
  title="Self-hosted stacks — update dashboards — Bumplog"
  description="Curated bundles of self-hosted apps. Bookmark a stack to track all its apps' update safety on one dashboard."
>
  <div class="page-hero">
    <h1>Self-hosted stacks</h1>
    <p class="lede">
      Curated bundles of apps that go together. Bookmark a stack to watch every
      app's update safety on a single dashboard.
    </p>
  </div>

  {allStacks.length === 0 ? (
    <div class="empty-state">
      <p>No stacks defined yet.</p>
    </div>
  ) : (
    <ul class="grid">
      {allStacks.map((stack) => {
        const { total, assessed } = stackStatus(stack);
        return (
          <li>
            <a class="card stack-card" href={`/stacks/${stack.slug}/`}>
              <span class="stack-card__name">{stack.name}</span>
              <span class="muted stack-card__desc">{stack.description}</span>
              <span class="stack-card__foot muted">
                <span>{total} app{total === 1 ? '' : 's'}</span>
                <span aria-hidden="true">·</span>
                <span>{assessed} assessed</span>
              </span>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</BaseLayout>

<style>
  .stack-card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    height: 100%;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }
  .stack-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-border-strong);
  }
  .stack-card__name {
    font-weight: 700;
    font-size: var(--text-md);
    letter-spacing: -0.01em;
  }
  .stack-card__desc {
    font-size: var(--text-sm);
    line-height: 1.55;
  }
  .stack-card__foot {
    display: flex;
    gap: 0.5rem;
    font-size: var(--text-xs);
    margin-top: auto;
    padding-top: 0.3rem;
  }
</style>
