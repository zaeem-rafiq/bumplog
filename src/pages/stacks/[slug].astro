---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SafeToUpdateBadge from '../../components/SafeToUpdateBadge.astro';
import apps from '../../data/apps.json';
import stacks from '../../data/stacks.json';
import { toBadgeStatus, type App, type Stack, type SafeToUpdate } from '../../data/types';

export function getStaticPaths() {
  const allApps = apps as App[];
  const appBySlug = new Map(allApps.map((app) => [app.slug, app]));

  return (stacks as Stack[]).map((stack) => {
    // Resolve referenced app slugs to full app records; skip any unknown slug.
    const stackApps = stack.appSlugs
      .map((slug) => appBySlug.get(slug))
      .filter((app): app is App => app !== undefined);
    return {
      params: { slug: stack.slug },
      props: { stack, stackApps },
    };
  });
}

interface Props {
  stack: Stack;
  stackApps: App[];
}

const { stack, stackApps } = Astro.props;

// Sort assessed-first (safe → caution → breaking), pending last.
const ORDER: Record<SafeToUpdate, number> = { safe: 0, caution: 1, breaking: 2, unknown: 3 };
const sortedApps = [...stackApps].sort((a, b) => {
  const d = ORDER[toBadgeStatus(a.safeToUpdate)] - ORDER[toBadgeStatus(b.safeToUpdate)];
  return d !== 0 ? d : a.name.localeCompare(b.name);
});

const assessed = stackApps.filter((a) => a.safeToUpdate != null).length;
const needsCare = stackApps.filter(
  (a) => a.safeToUpdate === 'caution' || a.safeToUpdate === 'breaking',
).length;
---

<BaseLayout
  title={`${stack.name} self-hosted stack — update dashboard — Bumplog`}
  description={`Update dashboard for the ${stack.name} self-hosted stack: ${stack.description} Track every app's update safety in one place.`}
  ogType="article"
  wide={true}
>
  <article>
    <p class="breadcrumb"><a href="/stacks/">Stacks</a> <span aria-hidden="true">/</span> {stack.name}</p>
    <h1>{stack.name} stack</h1>
    <p class="lede">{stack.description}</p>

    {stackApps.length > 0 && (
      <ul class="summary" aria-label="Stack summary">
        <li class="summary__item">
          <span class="summary__num">{stackApps.length}</span> app{stackApps.length === 1 ? '' : 's'}
        </li>
        <li class="summary__item">
          <span class="summary__num">{assessed}</span> assessed
        </li>
        {needsCare > 0 ? (
          <li class="summary__item">
            <span class="summary__dot summary__dot--caution"></span>
            <span class="summary__num">{needsCare}</span> need a closer look
          </li>
        ) : assessed > 0 ? (
          <li class="summary__item">
            <span class="summary__dot summary__dot--safe"></span>
            All assessed apps look safe
          </li>
        ) : null}
      </ul>
    )}

    <h2>Apps in this stack</h2>
    {sortedApps.length === 0 ? (
      <div class="empty-state">
        <p>This stack has no apps yet.</p>
      </div>
    ) : (
      <ul class="stack-list">
        {sortedApps.map((app) => {
          const status = toBadgeStatus(app.safeToUpdate);
          return (
            <li class={`stack-row stack-row--${status}`}>
              <span class="stack-row__rail" aria-hidden="true"></span>
              <div class="stack-row__main">
                <a class="stack-row__name" href={`/apps/${app.slug}/`}>{app.name}</a>
                <span class="muted stack-row__repo">{app.repo}</span>
              </div>
              <div class="stack-row__meta">
                {app.latestVersion ? (
                  <span class="stack-row__version">{app.latestVersion}</span>
                ) : (
                  <span class="placeholder">version pending</span>
                )}
                <SafeToUpdateBadge status={status} size="sm" />
              </div>
            </li>
          );
        })}
      </ul>
    )}
  </article>
</BaseLayout>

<style>
  .stack-list {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .stack-row {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.85rem 1rem 0.85rem 1.25rem;
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }
  .stack-row__rail {
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: var(--status-unknown-solid);
  }
  .stack-row--safe .stack-row__rail { background: var(--status-safe-solid); }
  .stack-row--caution .stack-row__rail { background: var(--status-caution-solid); }
  .stack-row--breaking .stack-row__rail { background: var(--status-breaking-solid); }
  .stack-row--unknown {
    background: var(--color-surface-2);
  }
  .stack-row__main {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .stack-row__name {
    font-weight: 700;
    font-size: var(--text-md);
    text-decoration: none;
    color: inherit;
    letter-spacing: -0.01em;
  }
  .stack-row__name:hover {
    color: var(--color-link);
  }
  .stack-row__repo {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
  }
  .stack-row__meta {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .stack-row__version {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
