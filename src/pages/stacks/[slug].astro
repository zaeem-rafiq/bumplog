---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SafeToUpdateBadge from '../../components/SafeToUpdateBadge.astro';
import apps from '../../data/apps.json';
import stacks from '../../data/stacks.json';
import { toBadgeStatus, type App, type Stack, type SafeToUpdate } from '../../data/types';

export function getStaticPaths() {
  const allApps = apps as App[];
  const appBySlug = new Map(allApps.map((app) => [app.slug, app]));

  return (stacks as Stack[]).map((stack) => {
    // Resolve referenced app slugs to full app records; skip any unknown slug.
    const stackApps = stack.appSlugs
      .map((slug) => appBySlug.get(slug))
      .filter((app): app is App => app !== undefined);
    return {
      params: { slug: stack.slug },
      props: { stack, stackApps },
    };
  });
}

interface Props {
  stack: Stack;
  stackApps: App[];
}

const { stack, stackApps } = Astro.props;

// Sort assessed-first (safe → caution → breaking), pending last.
const ORDER: Record<SafeToUpdate, number> = { safe: 0, caution: 1, breaking: 2, unmaintained: 3, unknown: 4 };
const sortedApps = [...stackApps].sort((a, b) => {
  const d = ORDER[toBadgeStatus(a.safeToUpdate)] - ORDER[toBadgeStatus(b.safeToUpdate)];
  return d !== 0 ? d : a.name.localeCompare(b.name);
});

const assessed = stackApps.filter((a) => a.safeToUpdate != null).length;
const needsCare = stackApps.filter(
  (a) => a.safeToUpdate === 'caution' || a.safeToUpdate === 'breaking',
).length;
---

<BaseLayout
  title={`${stack.name} self-hosted stack — update dashboard — Bumplog`}
  description={`Update dashboard for the ${stack.name} self-hosted stack: ${stack.description} Track every app's update safety in one place.`}
  ogType="article"
  wide={true}
>
  <link
    rel="alternate"
    type="application/rss+xml"
    slot="head"
    title={`Bumplog — ${stack.name} stack updates`}
    href={`/stacks/${stack.slug}/feed.xml`}
  />
  <article>
    <p class="breadcrumb"><a href="/stacks/">Stacks</a> <span aria-hidden="true">/</span> {stack.name}</p>
    <h1>{stack.name} stack</h1>
    <p class="lede">
      {stack.description}
      <a class="stack-feed" href={`/stacks/${stack.slug}/feed.xml`}>Follow this stack via RSS</a>
    </p>

    {stackApps.length > 0 && (
      <ul class="summary" aria-label="Stack summary">
        <li class="summary__item">
          <span class="summary__num">{stackApps.length}</span> app{stackApps.length === 1 ? '' : 's'}
        </li>
        <li class="summary__item">
          <span class="summary__num">{assessed}</span> assessed
        </li>
        {needsCare > 0 ? (
          <li class="summary__item">
            <span class="summary__dot summary__dot--caution"></span>
            <span class="summary__num">{needsCare}</span> need a closer look
          </li>
        ) : assessed > 0 ? (
          <li class="summary__item">
            <span class="summary__dot summary__dot--safe"></span>
            All assessed apps look safe
          </li>
        ) : null}
      </ul>
    )}

    <h2>Apps in this stack</h2>
    {sortedApps.length === 0 ? (
      <div class="empty-state">
        <p>This stack has no apps yet.</p>
      </div>
    ) : (
      <ul class="stack-list">
        {sortedApps.map((app) => {
          const status = toBadgeStatus(app.safeToUpdate);
          return (
            <li class="stack-row" data-status={status}>
              <a class="stack-row__link" href={`/apps/${app.slug}/`}>
                <span class="stack-row__main">
                  <span class="stack-row__name">{app.name}</span>
                  <span class="stack-row__repo mono">{app.repo}</span>
                </span>
                <span class="stack-row__meta">
                  {app.latestVersion ? (
                    <span class="stack-row__version mono">{app.latestVersion}</span>
                  ) : (
                    <span class="stack-row__version mono placeholder">pending</span>
                  )}
                  <SafeToUpdateBadge status={status} size="sm" />
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </article>
</BaseLayout>

<style>
  .stack-feed {
    display: block;
    margin-top: 0.4rem;
    font-size: var(--text-sm);
  }
  .stack-list {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }
  .stack-row__link {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem 1.25rem;
    padding: 1.05rem 0;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--color-border);
  }
  .stack-row__link:hover .stack-row__name {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .stack-row__main {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .stack-row__name {
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .stack-row__repo {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
  .stack-row__meta {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .stack-row__version {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    white-space: nowrap;
  }
</style>
