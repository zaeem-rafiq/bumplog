---
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { JournalEntry } from '../../data/types';

export function getStaticPaths() {
  // TODO(harness): the harness appends dated journal entries here. Each path is
  // `{ params: { date }, props: { entry } }` keyed by ISO date (e.g. 2026-06-26).
  // Empty for now — no journal pages are pre-rendered until entries exist.
  const entries: JournalEntry[] = [];
  return entries.map((entry) => ({
    params: { date: entry.date },
    props: { entry },
  }));
}

interface Props {
  entry: JournalEntry;
}

const { entry } = Astro.props;
---

<BaseLayout
  title={`${entry.title} — Bumplog`}
  description={`Journal entry for ${entry.date}: ${entry.title}.`}
  ogType="article"
>
  <article>
    <p class="muted breadcrumb"><a href="/journal/">Journal</a> / {entry.date}</p>
    <h1>{entry.title}</h1>
    <p><time datetime={entry.date}>{entry.date}</time></p>
    <div class="entry-body" set:html={entry.body}></div>
  </article>
</BaseLayout>

<style>
  .breadcrumb {
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
</style>
