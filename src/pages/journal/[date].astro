---
import BaseLayout from '../../layouts/BaseLayout.astro';
import journal from '../../data/journal.json';

// The harness appends dated entries to src/data/journal.json. Each path is keyed
// by ISO date. `body` is the agent's plain-text narrative — rendered as ESCAPED
// text (never set:html) so model output can't inject markup.
interface JournalRow {
  date: string;
  title: string;
  body: string;
  stage?: string;
  day_index?: number;
  metrics?: Record<string, number>;
}

export function getStaticPaths() {
  return (journal as JournalRow[]).map((entry) => ({
    params: { date: entry.date },
    props: { entry },
  }));
}

interface Props {
  entry: JournalRow;
}

const { entry } = Astro.props;
const dayLabel =
  entry.day_index != null
    ? `Day ${entry.day_index}${entry.stage ? ` · ${entry.stage}` : ''}`
    : null;
---

<BaseLayout
  title={`${entry.title} — Bumplog`}
  description={`Journal entry for ${entry.date}: ${entry.title}.`}
  ogType="article"
>
  <article class="journal-article">
    <p class="breadcrumb"><a href="/journal/">Journal</a> <span aria-hidden="true">/</span> {entry.date}</p>
    <h1>{entry.title}</h1>
    <p class="entry-meta">
      <time datetime={entry.date}>{entry.date}</time>
      {dayLabel && <span class="entry-meta__day">{dayLabel}</span>}
    </p>
    <div class="entry-body">{entry.body}</div>
  </article>
</BaseLayout>

<style>
  .journal-article {
    max-width: 42rem;
  }
  .entry-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.85rem;
    margin-block: 0.4rem 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .entry-meta__day {
    color: var(--color-accent);
    font-weight: 660;
  }
  /* Preserve the agent's paragraph breaks without rendering raw HTML. */
  .entry-body {
    white-space: pre-line;
    margin-top: 1.5rem;
    font-size: var(--text-md);
    line-height: 1.72;
  }
</style>
