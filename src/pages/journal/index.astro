---
import BaseLayout from '../../layouts/BaseLayout.astro';
import journal from '../../data/journal.json';

// The harness appends dated entries to src/data/journal.json (most-recent first).
// Each entry carries more fields (stage, day_index, metrics); the index needs
// only date + title.
interface JournalRow {
  date: string;
  title: string;
}
const entries = (journal as JournalRow[])
  .slice()
  .sort((a, b) => (a.date < b.date ? 1 : -1));
---

<BaseLayout
  title="Update journal — Bumplog"
  description="A dated log of notable self-hosted app releases, breaking changes, and update advisories, tracked by Bumplog."
>
  <h1>Update journal</h1>
  <p class="lede">
    A running, dated log of notable releases and update advisories across the
    self-hosted apps we track.
  </p>

  {entries.length === 0 ? (
    <div class="empty-state">
      <p>No journal entries yet. New entries will appear here as they are published.</p>
    </div>
  ) : (
    <ul class="journal-list">
      {entries.map((entry) => (
        <li>
          <time datetime={entry.date}>{entry.date}</time>
          <a href={`/journal/${entry.date}/`}>{entry.title}</a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  .journal-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .journal-list li {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
</style>
