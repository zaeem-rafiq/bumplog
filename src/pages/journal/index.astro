---
import BaseLayout from '../../layouts/BaseLayout.astro';
import journal from '../../data/journal.json';

// The harness appends dated entries to src/data/journal.json (most-recent first).
// Each entry carries more fields (stage, day_index, metrics); the index uses
// date + title + the optional day marker.
interface JournalRow {
  date: string;
  title: string;
  stage?: string;
  day_index?: number;
}
const entries = (journal as JournalRow[])
  .slice()
  .sort((a, b) => (a.date < b.date ? 1 : -1));
---

<BaseLayout
  title="Update journal — Bumplog"
  description="A dated log of notable self-hosted app releases, breaking changes, and update advisories, tracked by Bumplog."
>
  <div class="page-hero">
    <h1>Update journal</h1>
    <p class="lede">
      A running, dated log of notable releases and update advisories across the
      self-hosted apps we track.
    </p>
  </div>

  {entries.length === 0 ? (
    <div class="empty-state">
      <p>No journal entries yet. New entries will appear here as they're published.</p>
    </div>
  ) : (
    <ol class="journal-list">
      {entries.map((entry) => (
        <li>
          <a class="journal-entry" href={`/journal/${entry.date}/`}>
            <span class="journal-entry__meta">
              <time datetime={entry.date}>{entry.date}</time>
              {entry.day_index != null && (
                <span class="journal-entry__day">
                  Day {entry.day_index}{entry.stage ? ` · ${entry.stage}` : ''}
                </span>
              )}
            </span>
            <span class="journal-entry__title">{entry.title}</span>
          </a>
        </li>
      ))}
    </ol>
  )}
</BaseLayout>

<style>
  .journal-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }
  .journal-entry {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .journal-entry:hover .journal-entry__title {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .journal-entry__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.85rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    margin-bottom: 0.45rem;
  }
  .journal-entry__day {
    color: var(--color-accent);
    font-weight: 600;
  }
  .journal-entry__title {
    display: block;
    font-family: var(--font-serif);
    font-weight: 430;
    font-size: var(--text-lg);
    letter-spacing: -0.01em;
    color: var(--color-text);
    line-height: 1.2;
  }
</style>
