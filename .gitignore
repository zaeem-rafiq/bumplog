# ── Secrets (NEVER commit) ───────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Node / Astro ─────────────────────────────────────────────────────────
node_modules/
dist/
.astro/
.output/
.vercel/
.netlify/
# wrangler local state (miniflare sqlite/KV blobs from `wrangler pages dev`)
.wrangler/

# ── Harness runtime artifacts ────────────────────────────────────────────
harness/cache/
harness/.posthog-cache/
harness/.gh-cache/
*.log

# ── Impeccable design tooling (installed per-project; not product source) ──
.claude/
.impeccable/*
# Keep the detector config tracked (waives a false-strict flat-type flag on the
# stacks index, whose small-text scale — caption/label/body — is necessarily tight).
!.impeccable/config.json

# ── OS / editor ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Playwright MCP run artifacts
.playwright-mcp/
